[Unit]
Description=OpenClaw Gateway
After=network.target openclaw-google-proxy.service

[Service]
Type=simple
ExecStart=/www/server/nvm/versions/node/v22.20.0/bin/openclaw gateway
Restart=always
RestartSec=5
Environment=OPENAI_API_KEY=your_openai_key_here
Environment=GEMINI_API_KEY=your_gemini_key_here
Environment=PATH=/root/.local/bin:/www/server/nvm/versions/node/v22.20.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=multi-user.target
